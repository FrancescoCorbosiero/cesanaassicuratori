{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "cesana/testimonials",
    "version": "1.0.0",
    "title": "Testimonials Slider",
    "category": "cesana",
    "icon": "format-quote",
    "description": "Slider di testimonianze con drag/swipe, citazioni in serif italic e navigazione avanzata.",
    "keywords": ["testimonials", "slider", "citazioni", "recensioni", "clienti"],
    "textdomain": "cesana-assicuratori-blocks",
    "attributes": {
        "eyebrow": {
            "type": "string",
            "default": "Testimonianze"
        },
        "title": {
            "type": "string",
            "default": "Cosa Dicono i Nostri Clienti"
        },
        "testimonials": {
            "type": "array",
            "default": [
                {
                    "quote": "Professionalità e disponibilità fuori dal comune. Cesana Assicuratori ha trovato la soluzione perfetta per la nostra azienda.",
                    "author": "Marco Rossi",
                    "role": "Amministratore Delegato, Rossi S.r.l.",
                    "photo": ""
                },
                {
                    "quote": "Finalmente un broker che ascolta davvero le esigenze del cliente. Consigliato a chiunque cerchi trasparenza e competenza.",
                    "author": "Laura Bianchi",
                    "role": "Libera Professionista",
                    "photo": ""
                }
            ]
        },
        "autoplay": {
            "type": "number",
            "default": 6000
        }
    },
    "supports": {
        "align": ["wide", "full"],
        "html": false
    },
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
