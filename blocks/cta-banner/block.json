{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "cesana/cta-banner",
    "version": "1.0.0",
    "title": "CTA Banner",
    "category": "cesana",
    "icon": "megaphone",
    "description": "Banner call-to-action a larghezza piena con varianti navy, oro e chiaro.",
    "keywords": ["cta", "banner", "azione", "contatto", "consulenza"],
    "textdomain": "cesana-assicuratori-blocks",
    "requiresAtLeast": "6.5",
    "attributes": {
        "eyebrow": {
            "type": "string",
            "default": ""
        },
        "title": {
            "type": "string",
            "default": "Proteggi Ci\u00f2 Che Conta"
        },
        "text": {
            "type": "string",
            "default": "Richiedi una consulenza gratuita e senza impegno con i nostri esperti."
        },
        "buttonText": {
            "type": "string",
            "default": "Contattaci"
        },
        "buttonUrl": {
            "type": "string",
            "default": ""
        },
        "backgroundImage": {
            "type": "string",
            "default": ""
        },
        "variant": {
            "type": "string",
            "default": "navy",
            "enum": ["navy", "gold", "light"]
        }
    },
    "supports": {
        "align": ["full"],
        "html": false
    },
    "example": {},
    "editorScript": "file:./editor.js",
    "style": "file:./style.css",
    "render": "file:./render.php"
}
