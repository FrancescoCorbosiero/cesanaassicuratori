{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "cesana/testimonial-stats",
    "version": "1.0.0",
    "title": "Testimonial Stats",
    "category": "cesana",
    "icon": "chart-bar",
    "description": "Sezione statistiche animate con contatore: anni di esperienza, soddisfazione clienti, convenzioni.",
    "keywords": ["stats", "statistiche", "contatore", "numeri", "testimonial"],
    "textdomain": "cesana-assicuratori-blocks",
    "requiresAtLeast": "6.5",
    "attributes": {
        "title": {
            "type": "string",
            "default": ""
        },
        "stats": {
            "type": "array",
            "default": [
                {
                    "value": "25",
                    "suffix": "+",
                    "label": "Anni di Esperienza"
                },
                {
                    "value": "98",
                    "suffix": "%",
                    "label": "Clienti Soddisfatti"
                },
                {
                    "value": "50",
                    "suffix": "+",
                    "label": "Compagnie Partner"
                }
            ]
        },
        "variant": {
            "type": "string",
            "default": "navy",
            "enum": ["navy", "light"]
        }
    },
    "supports": {
        "align": ["wide", "full"],
        "html": false
    },
    "example": {},
    "editorScript": "file:./editor.js",
    "style": "file:./style.css",
    "render": "file:./render.php"
}
